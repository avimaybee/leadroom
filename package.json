{
  "name": "leadroom",
  "version": "1.0.0",
  "description": "Internal operating system for Leadroom",
  "scripts": {
    "build": "next build --webpack",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint src/",
    "test": "node --import tsx --test",
    "test:sdr-smoke": "node --import tsx src/lib/domain/__tests__/sdr-smoke.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply leadroom --local",
    "db:migrate:remote": "wrangler d1 migrations apply leadroom --remote",
    "db:seed": "node --import tsx src/db/seed.ts",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@cloudflare/puppeteer": "^1.1.0",
    "@google/jules-sdk": "^0.2.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "firebase": "^12.15.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260610.1",
    "@google/jules-cli": "https://firebasestorage.googleapis.com/v0/b/alpha-note-274ac.appspot.com/o/jules%2Flatest.tgz?alt=media",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.100.0"
  }
}
