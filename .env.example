# === Required ===

# JWT session signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# === Google Calendar OAuth ===
# Used by the calendar integration for meeting scheduling.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Cloudflare D1 (for remote DB operations) ===
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# === Cloudflare Workflow bindings ===
# Set in wrangler.jsonc for production; set here as env vars for local dev.
MONITOR_STALLED_LEAD_WORKFLOW=
RESEARCH_SNAPSHOT_WORKFLOW=
DISCOVERY_SEARCH_WORKFLOW=

# === Database (D1 binding name) ===
# Configured in wrangler.jsonc; can also be set as env var for local dev.
DB=

# === Database Credential Encryption ===
# AES-GCM encryption key for sensitive credentials in D1 (API keys, OAuth tokens).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If this key is not set, integrations.ts and calendar.ts will throw an error at runtime.
DB_ENCRYPTION_KEY=

# === Cron / Scheduled Tasks ===
# Secret used to authenticate cron job invocations.
CRON_SECRET=

# === Rate Limiting ===
# Sliding-window rate limit configuration for AI provider calls.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# === Firebase (optional) ===
# Used for Firebase Auth integration if enabled.
FIREBASE_API_KEY=

# === AI Provider Keys ===
# Configure at least one in Settings > Integrations (stored in D1).
# GEMINI_API_KEY is the fallback if no provider is configured in the DB.
GEMINI_API_KEY=

# === Jina Reader for website scraping ===
# Optional; works without a key at lower rate limits.
JINA_API_KEY=

# === Apify for discovery search ===
# Required only for the Discovery > Search feature (Google Maps scraping).
APIFY_API_TOKEN=

# === Jules Integration ===
# REQUIRED for Jules API integration. Generate a new key — the old one was rotated (committed to git).
JULES_API_KEY=
JULES_WORKSPACE=
