# === Required ===

# JWT session signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# === Google Calendar OAuth ===
# Used by the calendar integration for meeting scheduling.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Cloudflare D1 (for remote DB operations) ===
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# === Cloudflare Workflow bindings ===
# Set in wrangler.jsonc for production; set here as env vars for local dev.
MONITOR_STALLED_LEAD_WORKFLOW=
RESEARCH_SNAPSHOT_WORKFLOW=
DISCOVERY_SEARCH_WORKFLOW=

# === Database (D1 binding name) ===
# Configured in wrangler.jsonc; can also be set as env var for local dev.
DB=

# === AI Provider Keys ===
# Configure at least one in Settings > Integrations (stored in D1).
# GEMINI_API_KEY is the fallback if no provider is configured in the DB.
GEMINI_API_KEY=

# === Jina Reader for website scraping ===
# Optional; works without a key at lower rate limits.
JINA_API_KEY=

# === Apify for discovery search ===
# Required only for the Discovery > Search feature (Google Maps scraping).
APIFY_API_TOKEN=
